VITE_INSFORGE_URL=https://your-project.region.insforge.app
VITE_INSFORGE_ANON_KEY=your-anon-key

# Optional public Web Push key. Leave blank until push subscriptions are enabled
# in the deployed backend. This key is safe to expose; the private key is not.
VITE_WEB_PUSH_PUBLIC_KEY=

# Server-only InsForge edge-function secrets. Never prefix these with VITE_.
# Keep real values in .env.local for local development and upload them with
# `insforge secrets add` for deployed functions.
INSFORGE_BASE_URL=https://your-project.region.insforge.app
INSFORGE_API_KEY=your-project-admin-key
GEMINI_API_KEY=your-gemini-api-key
GEMINI_PROOF_MODEL=gemini-3.5-flash
ALLOWED_ORIGINS=http://localhost:5173
DAILY_MAINTENANCE_SECRET=replace-with-64-random-hex-characters
